{
  "expo": {
    "name": "CampusBites",
    "slug": "wmt_assignment",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/campusbites-logo-minimal.png",
    "scheme": "wmtassignment",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E7F3F2",
        "foregroundImage": "./assets/images/campusbites-logo-minimal.png"
      },
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "package": "com.anonymous.wmt_assignment",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E7F3F2",
          "android": {
            "image": "./assets/images/campusbites-logo-minimal.png",
            "imageWidth": 120
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to scan pickup QR codes for orders."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f22e5a15-c93a-40de-8230-7029708b118a"
      }
    }
  }
}
